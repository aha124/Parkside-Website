# Parkside Website Environment Variables
# Copy this file to .env.local and fill in your values

# ===========================================
# AUTHENTICATION (NextAuth.js v5)
# ===========================================

# Your production URL (or http://localhost:3000 for development)
NEXTAUTH_URL=http://localhost:3000

# Generate a random secret: openssl rand -base64 32
NEXTAUTH_SECRET=your-secret-key-here

# ===========================================
# GOOGLE OAUTH
# ===========================================
# Create at: https://console.cloud.google.com/apis/credentials
# Authorized redirect URI: {NEXTAUTH_URL}/api/auth/callback/google

GOOGLE_CLIENT_ID=your-google-client-id
GOOGLE_CLIENT_SECRET=your-google-client-secret

# ===========================================
# GITHUB OAUTH
# ===========================================
# Create at: https://github.com/settings/developers
# Authorization callback URL: {NEXTAUTH_URL}/api/auth/callback/github

GITHUB_CLIENT_ID=your-github-client-id
GITHUB_CLIENT_SECRET=your-github-client-secret

# ===========================================
# ADMIN ACCESS
# ===========================================
# Comma-separated list of email addresses that can access admin
# This is a fallback - admins can also be added via the admin UI

ADMIN_EMAILS=admin@example.com,another-admin@example.com

# ===========================================
# VERCEL KV (Redis)
# ===========================================
# These are auto-populated when you add KV storage in Vercel
# For local development, you can use Vercel CLI: vercel env pull

KV_URL=
KV_REST_API_URL=
KV_REST_API_TOKEN=
KV_REST_API_READ_ONLY_TOKEN=

# ===========================================
# VERCEL BLOB (File Storage)
# ===========================================
# This is auto-populated when you add Blob storage in Vercel

BLOB_READ_WRITE_TOKEN=

# ===========================================
# CONTACT FORM
# ===========================================
# Email address where contact form submissions are sent
# Get a Resend API key at: https://resend.com/api-keys

RESEND_API_KEY=
CONTACT_FORM_EMAIL=info@parksideharmony.org
